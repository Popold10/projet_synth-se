#!/usr/bin/env python3
"""
Alerte securite Wazuh + Ollama (cron) -- envoi via Brevo (HTTPS)
-----------------------------------------------------------------
Deux volets surveilles sur une fenetre de temps :
  A) ECHECS D'AUTHENTIFICATION au domaine (par utilisateur et par IP, comptes
     machine exclus). Alerte si un compte OU une IP depasse un seuil.
  B) CONFORMITE DES POSTES (Microsoft Defender / pare-feu Windows, via WEF,
     regles 100600-100611). Alerte si un evenement significatif remonte.
Le mail part si l'un OU l'autre volet declenche : analyse IA + evenements bruts.
Sinon, aucun mail.

Detection auth par AGREGATION (comme le rapport web), et non par la regle 100201 :
cela capte aussi les brute-force LENTES que la correlation 5-en-2-min rate.
"""

import os
import json
from datetime import datetime, timedelta, timezone

import requests
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# ===== CONFIGURATION (reporte tes valeurs depuis l'ancien script) =====
OPENSEARCH_URL  = "https://192.168.2.50:9200"
OPENSEARCH_USER = "admin"
OPENSEARCH_PASS = "TON_MDP"
INDEX           = "wazuh-alerts-*"
VERIFY_SSL      = False
TIME_FIELD      = "timestamp"

LOOKBACK_HOURS    = 24    # fenetre d'analyse ; doit correspondre a la frequence du cron
FAILURE_THRESHOLD = 5     # alerte si un compte OU une IP atteint ce nb d'echecs
FAIL_EVENT_IDS    = ["4625", "4771", "4776"]
MAX_EVENTS        = 50

# Conformite postes : niveau minimal d'alerte qui declenche un mail
#   8 = critique (RTP/pare-feu coupes, malware, analyse desactivee)
#   6 = inclut aussi les echecs de maj de signatures | 3 = tout
EP_MIN_LEVEL      = 8

HISTORY_FILE = "/opt/rapport-wazuh/historique_alertes.jsonl"  # memoire des alertes
HISTORY_DAYS = 7                                              # roulement (1 semaine)

OLLAMA_URL   = "http://localhost:11434/api/generate"
OLLAMA_MODEL = "llama3:8b"

BREVO_API_KEY = "xkeysib-TA_CLE"
SENDER_EMAIL  = "alertes@dietagro.com"     # expediteur verifie dans Brevo
SENDER_NAME   = "Wazuh Alerting"
TO_EMAIL      = "soc@dietagro.com"
TO_NAME       = "SOC"
# ======================================================================

CODES = {"0x18": "mauvais mot de passe", "0x12": "compte desactive/verrouille",
         "0x6": "utilisateur inconnu", "0x25": "decalage d'horloge",
         "0x17": "mot de passe expire"}

EP_EVENT_LABELS = {"1116": "malware detecte", "5001": "protection temps reel desactivee",
                   "5010": "analyse antivirus desactivee", "5012": "analyse antivirus desactivee",
                   "2001": "echec maj signatures Defender", "2003": "parametre pare-feu modifie"}


def fetch_failures():
    query = {
        "size": MAX_EVENTS,
        "sort": [{TIME_FIELD: {"order": "desc"}}],
        "query": {
            "bool": {
                "filter": [
                    {"range": {TIME_FIELD: {"gte": f"now-{LOOKBACK_HOURS}h"}}},
                    {"terms": {"data.win.system.eventID": FAIL_EVENT_IDS}},
                ]
            }
        },
        "aggs": {
            "par_user": {"terms": {"field": "data.win.eventdata.targetUserName", "size": 30}},
            "par_ip":   {"terms": {"field": "data.win.eventdata.ipAddress", "size": 30}},
            "par_code": {"terms": {"field": "data.win.eventdata.status", "size": 15}},
        },
    }
    r = requests.get(f"{OPENSEARCH_URL}/{INDEX}/_search", json=query,
                     auth=(OPENSEARCH_USER, OPENSEARCH_PASS),
                     verify=VERIFY_SSL, timeout=30)
    if not r.ok:
        print("REPONSE INDEXEUR:", r.text)
    r.raise_for_status()
    return r.json()


def buckets(resp, name):
    return resp.get("aggregations", {}).get(name, {}).get("buckets", [])


def user_buckets(resp):
    # exclut les comptes machine (se terminent par $) cote Python -> pas de wildcard
    return [b for b in buckets(resp, "par_user") if not str(b["key"]).endswith("$")]


def detect(resp):
    """Comptes et IP qui depassent le seuil d'echecs."""
    off_users = [b for b in user_buckets(resp) if b["doc_count"] >= FAILURE_THRESHOLD]
    off_ips   = [b for b in buckets(resp, "par_ip") if b["doc_count"] >= FAILURE_THRESHOLD]
    return off_users, off_ips


def build_summary(resp):
    out = [f"Echecs d'authentification sur les {LOOKBACK_HOURS} dernieres heures "
           f"(comptes machine exclus) :", ""]
    out.append("Par utilisateur :")
    out += [f"  - {b['key']} : {b['doc_count']} echecs" for b in user_buckets(resp)] or ["  (aucun)"]
    out.append("\nPar IP source :")
    out += [f"  - {b['key']} : {b['doc_count']} echecs" for b in buckets(resp, "par_ip")] or ["  (aucune)"]
    out.append("\nCodes d'erreur :")
    out += [f"  - {b['key']} ({CODES.get(b['key'], '?')}) : {b['doc_count']}"
            for b in buckets(resp, "par_code")] or ["  (aucun)"]
    return "\n".join(out)


def build_raw_list(resp):
    lines = []
    for hit in resp.get("hits", {}).get("hits", []):
        s = hit.get("_source", {})
        win = s.get("data", {}).get("win", {})
        d = win.get("eventdata", {})
        sysd = win.get("system", {})
        user = d.get("targetUserName", "?")
        if str(user).endswith("$"):
            continue  # ignore comptes machine
        lines.append(f"{s.get('timestamp', '?')} | event {sysd.get('eventID', '?')} | "
                     f"user {user} | ip {d.get('ipAddress', '?')} | "
                     f"regle {s.get('rule', {}).get('id', '?')}")
    return lines


# ===== Volet B : conformite des postes (Defender / pare-feu) =====
def fetch_endpoint_alerts():
    query = {
        "size": MAX_EVENTS,
        "sort": [{TIME_FIELD: {"order": "desc"}}],
        "query": {"bool": {"filter": [
            {"range": {TIME_FIELD: {"gte": f"now-{LOOKBACK_HOURS}h"}}},
            {"match": {"rule.groups": "endpoint_security"}},
            {"range": {"rule.level": {"gte": EP_MIN_LEVEL}}},
        ]}},
        "aggs": {
            "par_poste": {"terms": {"field": "data.win.system.computer", "size": 50}},
            "par_event": {"terms": {"field": "data.win.system.eventID", "size": 20}},
        },
    }
    r = requests.get(f"{OPENSEARCH_URL}/{INDEX}/_search", json=query,
                     auth=(OPENSEARCH_USER, OPENSEARCH_PASS),
                     verify=VERIFY_SSL, timeout=30)
    if not r.ok:
        print("REPONSE INDEXEUR (endpoint):", r.text)
    r.raise_for_status()
    return r.json()


def endpoint_total(resp):
    total = resp.get("hits", {}).get("total", 0)
    if isinstance(total, dict):
        total = total.get("value", 0)
    return total


def build_endpoint_summary(resp):
    total = endpoint_total(resp)
    if not total:
        return "Aucun evenement de conformite significatif sur la fenetre."
    out = [f"{total} evenements de conformite significatifs.", "", "Par poste :"]
    out += [f"  - {b['key']} : {b['doc_count']}" for b in buckets(resp, "par_poste")] or ["  (aucun)"]
    out.append("\nPar type d'evenement :")
    for b in buckets(resp, "par_event"):
        lbl = EP_EVENT_LABELS.get(str(b["key"]), "autre")
        out.append(f"  - {b['key']} ({lbl}) : {b['doc_count']}")
    return "\n".join(out)


def endpoint_raw_list(resp):
    lines = []
    for hit in resp.get("hits", {}).get("hits", []):
        s = hit.get("_source", {})
        win = s.get("data", {}).get("win", {}).get("system", {})
        lines.append(f"{s.get('timestamp', '?')} | {win.get('computer', '?')} | "
                     f"event {win.get('eventID', '?')} | {s.get('rule', {}).get('description', '?')}")
    return lines


def load_history():
    """Charge l'historique en ne gardant que les HISTORY_DAYS derniers jours (roulement)."""
    if not os.path.exists(HISTORY_FILE):
        return []
    cutoff = datetime.now(timezone.utc) - timedelta(days=HISTORY_DAYS)
    out = []
    with open(HISTORY_FILE, encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                e = json.loads(line)
                if datetime.fromisoformat(e["ts"]) >= cutoff:
                    out.append(e)
            except Exception:
                continue
    return out


def save_history(entries):
    os.makedirs(os.path.dirname(HISTORY_FILE) or ".", exist_ok=True)
    with open(HISTORY_FILE, "w", encoding="utf-8") as f:
        for e in entries:
            f.write(json.dumps(e, ensure_ascii=False) + "\n")


def build_history_summary(history):
    """Resume deterministe des alertes precedentes, injecte dans le prompt."""
    if not history:
        return "(aucune alerte enregistree sur les 7 derniers jours)"
    lines = []
    for e in history:
        u = ", ".join(f"{x['key']}({x['count']})" for x in e.get("users", [])) or "-"
        i = ", ".join(f"{x['key']}({x['count']})" for x in e.get("ips", [])) or "-"
        p = ", ".join(f"{x['key']}({x['count']})" for x in e.get("endpoints", [])) or "-"
        date = e.get("ts", "?")[:16].replace("T", " ")
        lines.append(f"- {date} | comptes: {u} | IP: {i} | postes: {p}")
    return "\n".join(lines)


PROMPT = """Tu es analyste SOC. Une alerte de securite vient d'etre declenchee : soit une suspicion \
de brute-force (un compte ou une IP a depasse le seuil d'echecs d'authentification au domaine), \
soit un probleme de conformite poste (Microsoft Defender / pare-feu Windows), soit les deux. \
Tu disposes aussi de l'HISTORIQUE des alertes des 7 derniers jours : sers-t'en pour reperer les \
RECURRENCES (meme compte, meme IP ou meme poste deja signale) et faire des liens entre incidents.

Redige une courte analyse en francais :
1. Resume de l'incident actuel, volet par volet (comptes, IP, postes et chiffres concernes).
2. Qualification - authentification : brute-force si les echecs visent UN SEUL compte ; password \
spray si plusieurs comptes distincts depuis une meme IP. Conformite : protection temps reel ou \
pare-feu desactives, malware detecte, signatures non a jour.
3. Mise en perspective : cet incident est-il une recurrence (deja vu dans l'historique) ? Y a-t-il \
un lien entre les deux volets (ex : un poste non conforme qui est aussi source d'echecs d'auth) ? \
Si rien ne correspond, dis-le.
4. Recommandations concretes.
Base-toi UNIQUEMENT sur les donnees fournies, n'invente aucun chiffre. Si un volet est vide, dis-le.

HISTORIQUE DES ALERTES PRECEDENTES (7 derniers jours) :
{history}

VOLET A - ECHECS D'AUTHENTIFICATION :
{summary}

VOLET B - CONFORMITE DES POSTES :
{ep_summary}
"""


def ask_ollama(summary, ep_summary, history_summary):
    try:
        r = requests.post(OLLAMA_URL,
                          json={"model": OLLAMA_MODEL,
                                "prompt": PROMPT.format(summary=summary, ep_summary=ep_summary,
                                                        history=history_summary),
                                "stream": False},
                          timeout=300)
        r.raise_for_status()
        return r.json().get("response", "(pas de reponse du modele)")
    except Exception as e:
        return f"(analyse IA indisponible : {e})"


def send_email(subject, body):
    payload = {"sender": {"name": SENDER_NAME, "email": SENDER_EMAIL},
               "to": [{"email": TO_EMAIL, "name": TO_NAME}],
               "subject": subject, "textContent": body}
    headers = {"api-key": BREVO_API_KEY,
               "Content-Type": "application/json", "Accept": "application/json"}
    r = requests.post("https://api.brevo.com/v3/smtp/email",
                      json=payload, headers=headers, timeout=30)
    if not r.ok:
        print("REPONSE BREVO:", r.status_code, r.text)
    r.raise_for_status()


def main():
    history = load_history()          # deja elague aux 7 derniers jours

    resp = fetch_failures()
    off_users, off_ips = detect(resp)

    ep_resp = fetch_endpoint_alerts()
    ep_total = endpoint_total(ep_resp)
    ep_postes = [b["key"] for b in buckets(ep_resp, "par_poste")]

    # rien sur aucun des deux volets -> pas de mail (mais on applique le roulement)
    if not off_users and not off_ips and not ep_total:
        save_history(history)
        return

    summary    = build_summary(resp)
    raw        = build_raw_list(resp)
    ep_summary = build_endpoint_summary(ep_resp)
    ep_raw     = endpoint_raw_list(ep_resp)
    analysis   = ask_ollama(summary, ep_summary, build_history_summary(history))

    # sujet : reflete ce qui a declenche l'alerte
    motifs = []
    if off_users or off_ips:
        cibles = ", ".join(b["key"] for b in off_users) or ", ".join(b["key"] for b in off_ips)
        motifs.append(f"brute-force ({cibles})")
    if ep_total:
        motifs.append(f"conformite postes ({', '.join(ep_postes) or '?'})")
    subject = "[Wazuh] " + " + ".join(motifs)

    body = ("=== ANALYSE (IA) ===\n\n" + analysis +
            "\n\n=== ECHECS BRUTS (comptes machine exclus) ===\n\n" + ("\n".join(raw) or "(aucun)") +
            "\n\n=== CONFORMITE POSTES (Defender / pare-feu) ===\n\n" + ep_summary +
            "\n\n" + ("\n".join(ep_raw) or "(aucun evenement brut)"))
    send_email(subject, body)

    # enregistre l'alerte dans l'historique (pour les analyses futures)
    history.append({
        "ts": datetime.now(timezone.utc).isoformat(),
        "users":     [{"key": b["key"], "count": b["doc_count"]} for b in off_users],
        "ips":       [{"key": b["key"], "count": b["doc_count"]} for b in off_ips],
        "endpoints": [{"key": b["key"], "count": b["doc_count"]} for b in buckets(ep_resp, "par_poste")],
    })
    save_history(history)
    print(subject, "-> mail envoye et enregistre")


if __name__ == "__main__":
    main()
