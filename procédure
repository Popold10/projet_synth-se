chmod 750 /var/ossec/integrations/llama_analysis.py
chown root:wazuh /var/ossec/integrations/llama_analysis.py

nano /var/ossec/etc/decoders/packetfence_decoders.xml

<decoder name="packetfence">
  <prematch>pfqueue</prematch>
</decoder>

<decoder name="packetfence_compliance">
  <parent>packetfence</parent>
  <regex>mac=(\S+) ip=(\S+) hostname=(\S+) user=(\S+) check=(\S+) expected=(\S+) found=(\S+) status=(\S+)</regex>
  <order>srcmac, srcip, hostname, srcuser, check, expected, found, status</order>
</decoder>


nano /var/ossec/etc/ossec.conf

<ossec_config>

  <integration>
    <name>llama</name>
    <rule_id>100201,100202,100203,100204,100205,100206,100207</rule_id>
    <script>/var/ossec/integrations/llama_analysis.py</script>
    <alert_format>json</alert_format>
  </integration>

</ossec_config>


systemctl restart wazuh-manager

# Vérifier que le décodeur reconnaît bien les logs
/var/ossec/bin/wazuh-logtest

